    </bpmn:startEvent>
    <bpmn:task id="t_gar" name="Evaluar garantia (depende del montaje)">
      <bpmn:incoming>f_26</bpmn:incoming>
      <bpmn:outgoing>f_27</bpmn:outgoing>
    </bpmn:task>
