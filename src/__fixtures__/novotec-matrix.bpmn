      <bpmn:outgoing>f_28</bpmn:outgoing>
      <bpmn:outgoing>f_29</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="end_gar_no" name="No cubre / discusion comercial">
      <bpmn:incoming>f_29</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t_papf" name="Trasladar puesta a punto final + probar">
