      <bpmn:outgoing>f_24</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="end_ok" name="Recibe el motor reparado">
      <bpmn:incoming>f_25</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t_tr_dev" name="Devolver el motor sin reparar">
